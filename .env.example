# AegisLedger — Full Environment Configuration (18 services)
# Copy to .env — never commit .env to source control

# CORE
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# DATABASE
DATABASE_URL=postgresql://aegis:password@localhost:5432/aegisledger
DATABASE_POOL_MAX=20

# REDIS — password is required (Fix 7)
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_MIN_32_CHARS
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379

# KAFKA — 3-broker cluster required (Fix 8)
# Format: comma-separated list of broker addresses
KAFKA_BROKERS=kafka-1:9092,kafka-2:9092,kafka-3:9092

# JWT
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM
JWT_EXPIRY=8h

# FIREBLOCKS
FIREBLOCKS_API_KEY=
FIREBLOCKS_SECRET_KEY=
MOCK_FIREBLOCKS=true

# COMPLIANCE (ComplyAdvantage)
COMPLY_ADVANTAGE_API_KEY=
TRAVEL_RULE_API_KEY=
SANCTIONS_RESCAN_INTERVAL_HOURS=24

# SMART CONTRACTS — runtime service connection addresses only
# DEPLOYER_PRIVATE_KEY must NEVER appear here.
# Smart contract deployment uses a hardware wallet (Ledger) or a
# CI/CD-only secrets vault. It is never available to running services.
# (Fix 44)
SMART_CONTRACT_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY
ETHERSCAN_API_KEY=

# Deployed contract addresses — populated after running deploy.js
ESCROW_CONTRACT_ADDRESS=
TRANCHE_ESCROW_CONTRACT_ADDRESS=
MULTISIG_CONTRACT_ADDRESS=
BOL_NFT_CONTRACT_ADDRESS=

# Treasury multisig — must be a Gnosis Safe or hardware wallet multisig
# NEVER use a raw EOA address here (Fix 51)
TREASURY_MULTISIG_ADDRESS=

# MultiSig deployment parameters (Fix 33)
# Comma-separated hardware wallet addresses — NEVER software wallets
MULTISIG_SIGNERS=0x...,0x...
MULTISIG_THRESHOLD=2
MULTISIG_TIMELOCK_SECONDS=86400
# Recovery address: cold hardware wallet, different keyholder from deployer
MULTISIG_RECOVERY_ADDRESS=0x...

# BoL NFT base URI
BOL_BASE_URI=https://aegisledger.io/api/bol/{id}.json

# Approved stablecoin contract address for escrow
APPROVED_STABLECOIN=

# Platform fee in basis points (15 = 0.15%)
PLATFORM_FEE_BPS=15

# Audit gate — set to true ONLY after formal audit report published (Fix 13)
# Never set this in .env — inject via CI/CD secrets vault only
# AUDIT_CONFIRMED=false

# Oracle key management — use AWS KMS, never store raw private key (Fix 49)
ORACLE_KMS_KEY_ID=

# FIAT (OpenPayd)
OPENPAYD_API_KEY=
OPENPAYD_API_SECRET=
MOCK_OPENPAYD=true

# EMAIL (SendGrid)
SENDGRID_API_KEY=
MOCK_EMAIL=true

# KYB (Sumsub)
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=

# BILLING (Stripe)
STRIPE_SECRET_KEY=sk_test_...
PLATFORM_FEE_BPS=15
FX_SPREAD_BPS=25

# AI (Anthropic)
ANTHROPIC_API_KEY=

# WEBHOOKS
WEBHOOK_SIGNING_SECRET=CHANGE_ME

# TELEGRAM / SLACK
TELEGRAM_BOT_TOKEN=
SLACK_WEBHOOK_URL=

# AWS
AWS_REGION=me-south-1
AWS_S3_BACKUP_BUCKET=aegisledger-backups

# OBSERVABILITY
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# SERVICE PORTS
IDENTITY_SERVICE_PORT=3001
WALLET_SERVICE_PORT=3002
COMPLIANCE_SERVICE_PORT=3003
TRADE_SERVICE_PORT=3004
FIAT_SERVICE_PORT=3005
NOTIFICATION_SERVICE_PORT=3006
WEBSOCKET_SERVICE_PORT=3007
KYB_SERVICE_PORT=3008
COMPLIANCE_ENGINE_PORT=3009
ANALYTICS_SERVICE_PORT=3010
AUTH_SERVICE_PORT=3011
BILLING_SERVICE_PORT=3012
DEVELOPER_PORTAL_PORT=3013
TRADING_SERVICE_PORT=3014
SCHEDULER_SERVICE_PORT=3015
WEBHOOK_SERVICE_PORT=3016
BUSINESS_MODEL_PORT=3017
AI_SERVICE_PORT=3018
