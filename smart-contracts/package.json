{
  "name": "aegisledger-smart-contracts",
  "version": "1.0.0",
  "description": "AegisLedger Smart Contracts — Trade Escrow, BoL NFT, MultiSig on Ethereum/Polygon",
  "scripts": {
    "compile":          "npx hardhat compile",
    "test":             "npx hardhat test",
    "test:watch":       "npx hardhat test --watch",
    "coverage":         "npx hardhat coverage",
    "deploy:local":     "npx hardhat run scripts/deploy.js --network hardhat",
    "deploy:sepolia":   "npx hardhat run scripts/deploy.js --network sepolia",
    "deploy:mumbai":    "npx hardhat run scripts/deploy.js --network mumbai",
    "deploy:mainnet":   "npx hardhat run scripts/deploy.js --network mainnet",
    "clean":            "npx hardhat clean"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "hardhat": "^2.19.4",
    "dotenv": "^16.4.1"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.1"
  }
}
